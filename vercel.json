{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/privacy-policy.html", "dest": "/privacy-policy.html" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}