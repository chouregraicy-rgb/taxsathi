{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/privacy-policy.html", "dest": "/privacy-policy.html" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.html" },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    { "src": "/(.*\\.(js|css|ico|png|svg|woff|woff2))", "dest": "/$1" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "/", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}